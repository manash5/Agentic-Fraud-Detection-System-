# =============================================================================
# docker/.env.example — copy to docker/.env and fill in real values.
#   cp docker/.env.example docker/.env
# docker/.env is gitignored (see .gitignore) — never commit real secrets.
# docker compose auto-loads docker/.env for ${VAR} substitution in the compose
# file. Nothing below is baked into an image; they are runtime/compose values.
# =============================================================================

# ---- Postgres (INTERNAL service; not exposed to the host) -------------------
POSTGRES_DB=fraud_detection_global
POSTGRES_USER=fraud
POSTGRES_PASSWORD=change_me_postgres        # REQUIRED — pick a strong password

# ---- Neo4j (INTERNAL service; graph agent) ----------------------------------
NEO4J_PASSWORD=change_me_neo4j              # REQUIRED — min 8 chars for Neo4j 5

# ---- Host port mapping (the ONLY 2 ports exposed) ---------------------------
BACKEND_PORT=8000                           # host port -> backend:8000
FRONTEND_PORT=3000                          # host port -> frontend:3000

# ---- App config -------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
SESSION_TTL_SECONDS=86400
DEMO_USER_MOBILE=9801234567

# ---- OTP / SMS (EasySendSMS) ------------------------------------------------
# OTP_DEV_MODE=1  -> no SMS sent; the OTP code is logged + returned as `devCode`
#                    in the transfer status payload (works with no SMS account).
# OTP_DEV_MODE=0  -> real SMS via EasySendSMS (requires a valid API key below).
OTP_DEV_MODE=1
EASYSENDSMS_API_KEY=                        # leave blank in dev mode
EASYSENDSMS_SENDER=GIMEBANK

# Note on connection targets: the compose file wires the backend to the
# datastores by DOCKER SERVICE NAME (postgres / redis / kafka / neo4j), NOT
# localhost. You do not set FRAUD_DB_DSN / FRAUD_REDIS_HOST / FRAUD_KAFKA_BOOTSTRAP
# / NEO4J_URI here — compose derives them from the values above.
